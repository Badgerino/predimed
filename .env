# Database configuration for dockerized MySQL (used by app container)
database.default.hostname = mysql
database.default.database = predimed
database.default.username = predimed
database.default.password = predimed
database.default.DBDriver = MySQLi
database.default.port = 3306

# If accessing the DB from the host machine (outside Docker), use:
# database.default.hostname = 127.0.0.1
# database.default.port = 3308
CI_ENVIRONMENT = development

app.baseURL = 'http://localhost:8080/'
app.indexPage = 'public/index.php'

